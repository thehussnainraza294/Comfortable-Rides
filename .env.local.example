# Copy this file to .env.local and fill in the two values from your
# Supabase project, under Project Settings and then API.
#
# The anon key is safe to expose in the browser. It only ever grants
# what your Row Level Security policies allow, and those policies
# permit reading but not writing.

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
